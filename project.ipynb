    "# Genere la función de pérdida\n",
    "def funcion_perdida(x_data, y_data, modelo):\n",
    "    N = len(x_data)\n",
    "\n",
    "    L = 0\n",
    "    for xi, yi in zip(x_data, y_data):\n",
    "        y_hat = modelo(xi)\n",
    "        L = L + (y_hat - yi)**2\n",
    "\n",
    "    return L / N"
   ]
